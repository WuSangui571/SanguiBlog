# ===========================================
# SanguiBlog Docker Compose 环境变量模板（.env.example）
#
# 使用方法：
# Step 1. 复制本文件，并将复制后的文件重命名为：.env
# Step 2. 在 .env 中填入真实部署值
#
# 注意：
# - 本模板中的敏感值默认留空，避免使用仓库内假密钥启动生产环境。
# - Docker Compose 会解析 .env 值中的 $。
#   如果密码或密钥包含 $，请用单引号包住整个值，例如：
#   JWT_SECRET='abc$def-very-long-secret'
# - 修改 .env 后，建议先执行下面命令检查 Compose 配置是否可解析：
#   docker compose -f docker-compose.prod.yml config --quiet
# ===========================================

# ---- 镜像拉取配置（生产环境从 GHCR 拉取，不要填 token） ----
# SANGUI_IMAGE_REGISTRY 默认 ghcr.io/wusangui571/sanguiblog
# SANGUI_IMAGE_TAG 默认 main；生产建议固定为 sha-<short_sha>，方便回滚部署
SANGUI_IMAGE_REGISTRY=ghcr.io/wusangui571/sanguiblog
SANGUI_IMAGE_TAG=main

# ---- Web 服务端口（默认 8090） ----
WEB_PORT=8090

# ---- JVM 内存限制（后端容器内 JVM 堆参数） ----
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Shanghai -Xms256m -Xmx512m

# ---- MySQL 主数据库 ----
# MYSQL_DATABASE 默认数据库名
# MYSQL_USER 默认业务用户
# MYSQL_PASSWORD 为数据库业务用户密码，请在 .env 中填写
# MYSQL_ROOT_PASSWORD 为 MySQL root 密码，请在 .env 中填写
MYSQL_DATABASE=sanguiblog_db
MYSQL_USER=sanguiblog_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---- PostgreSQL / PgVector（AI RAG 向量数据库） ----
# POSTGRES_DB 默认数据库名
# POSTGRES_USER 默认用户
# POSTGRES_PASSWORD 为 PgVector 数据库密码，请在 .env 中填写
POSTGRES_DB=sanguiblog_ai
POSTGRES_USER=sanguiblog_pg_user
POSTGRES_PASSWORD=

# ---- 后端 JWT 密钥（必填，建议 32+ 字符） ----
# 如果值中包含 $，请用单引号包住整个值
JWT_SECRET=

# ---- 后端 Spring Datasource（与 MySQL 配置保持一致） ----
# SPRING_DATASOURCE_USERNAME 通常和 MYSQL_USER 一致
# SPRING_DATASOURCE_PASSWORD 必须和 MYSQL_PASSWORD 一致
# JDBC URL 中使用 characterEncoding=utf8；不要写 utf8mb4，MySQL Connector/J 不支持该 Java charset 名称
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/sanguiblog_db?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=sanguiblog_user
SPRING_DATASOURCE_PASSWORD=

# ---- 上传存储路径（后端容器内路径） ----
STORAGE_BASE_PATH=/data/uploads

# ---- 站点基础 URL 和允许访问的 Host ----
# 本地默认：
SITE_BASE_URL=http://localhost:8090
SITE_ALLOWED_HOSTS=localhost
#
# 域名 + 8090 端口部署示例：
# SITE_BASE_URL=http://sangui.top
# SITE_ALLOWED_HOSTS=localhost,sangui.top
#
# HTTPS 反向代理部署示例：
# SITE_BASE_URL=https://sangui.top
# SITE_ALLOWED_HOSTS=localhost,sangui.top

# ---- 站点资源 URL ----
# 同源 Docker 部署请保持为空，这是推荐默认值。
# 不要设置为 http://sangui.top/uploads 这类 /uploads 路径，否则可能出现 /uploads/uploads/... 重复路径。
# 只有当资源由独立 CDN 或独立静态资源域名托管时，才填写完整 URL。
SITE_ASSET_BASE_URL=

# ---- CORS 允许源 ----
# 必须匹配浏览器实际访问源；包含协议，带端口访问时也必须包含端口。
# 本地默认：
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:8090
#
# 域名 + 8090 端口部署示例：
# SECURITY_CORS_ALLOWED_ORIGINS=http://sangui.top:8090
#
# HTTPS 反向代理部署示例：
# SECURITY_CORS_ALLOWED_ORIGINS=https://sangui.top

# ---- 兼容 OpenAI 格式的 AI 提供商（可选） ----
# 不配置 AI_OPENAI_API_KEY / AI_OPENAI_CHAT_MODEL 时，普通博客功能仍可正常使用，但 AI 聊天不可用。
# AI_OPENAI_BASE_URL 留空时默认使用 https://api.openai.com；末尾可带 /v1，后端会归一化。
# Chat model 用于 AI 对话。
AI_OPENAI_API_KEY=
AI_OPENAI_BASE_URL=
AI_OPENAI_CHAT_MODEL=

# Embedding model 用于 RAG 知识检索。
# AI_OPENAI_EMBEDDING_API_KEY / AI_OPENAI_EMBEDDING_BASE_URL 可留空，默认复用上面的 chat API key / base URL。
# 如果 embedding 使用不同 provider 或 endpoint，再单独填写这两个值。
# 如果 provider 不支持 embeddings，请保持 AI_RAG_ENABLED=false。
AI_OPENAI_EMBEDDING_API_KEY=
AI_OPENAI_EMBEDDING_BASE_URL=
AI_OPENAI_EMBEDDING_MODEL=

# ---- 已废弃：旧版 AI_DASHSCOPE_API_KEY ----
# AI_DASHSCOPE_API_KEY 已被上面的 OpenAI-compatible 配置替代。
# 请迁移到 AI_OPENAI_API_KEY、AI_OPENAI_BASE_URL、AI_OPENAI_CHAT_MODEL 和 AI_OPENAI_EMBEDDING_*。
# AI_DASHSCOPE_API_KEY=

# ---- 可选：AI RAG 与 PgVector 连接配置 ----
# AI_RAG_ENABLED 是 RAG 总开关。
# 建议在 AI_OPENAI_API_KEY、AI_OPENAI_CHAT_MODEL、AI_OPENAI_EMBEDDING_MODEL、PgVector 连接都确认可用后，再改为 true。
AI_RAG_ENABLED=false

# AI_RAG_SYNC_ON_STARTUP 控制后端启动完成后是否自动扫描并同步 RAG 向量。
# true 会扫描已发布文章和已启用的自定义知识库，按需生成/更新/清理向量。
# 生产建议保持 false，避免每次重启触发大量 embedding 调用和 PgVector 写入。
# 首次迁移、重建向量、确认有文章/知识库未向量化时，可临时改为 true。
AI_RAG_SYNC_ON_STARTUP=false

# PgVector 连接配置。默认指向 Compose 中的 pgvector 服务。
# AI_RAG_PGVECTOR_PASSWORD 通常和 POSTGRES_PASSWORD 一致。
AI_RAG_PGVECTOR_URL=jdbc:postgresql://pgvector:5432/sanguiblog_ai
AI_RAG_PGVECTOR_USERNAME=sanguiblog_pg_user
AI_RAG_PGVECTOR_PASSWORD=

# AI_RAG_PGVECTOR_INITIALIZE_SCHEMA 控制应用是否尝试初始化 PgVector 向量表结构。
# 首次启用 RAG 且 PgVector 的 vector_store 表还不存在时，可临时设为 true。
# 初始化完成后建议改回 false，避免生产启动时自动执行 DDL。
AI_RAG_PGVECTOR_INITIALIZE_SCHEMA=false

# ---- IP 地理位置（ip2region 本地 XDB） ----
# 后端在 classpath:ip2region/ip2region.xdb 处捆绑了一个默认的 IPv4 XDB 库。
# 可选 Docker 覆盖配置：将宿主机文件放在 ./docker/ip2region/ip2region.xdb，
# 然后取消注释下方路径，以便将其作为只读文件挂载到 /data/ip2region/。
# 下载源：https://github.com/lionsoul2014/ip2region/blob/master/data/ip2region_v4.xdb
# ANALYTICS_GEO_IP2REGION_XDB_PATH=/data/ip2region/ip2region.xdb