# ===========================================
# SanguiBlog Docker Compose environment template
# Copy this file to .env, then fill real production values.
#
# Important:
# - Keep secrets blank in this template.
# - Docker Compose interpolates $ in .env values. If a secret contains $, wrap
#   the whole value in single quotes, for example:
#   JWT_SECRET='abc$def-very-long-secret'
# - After editing .env, validate with:
#   docker compose -f docker-compose.prod.yml config --quiet
# ===========================================

# ---- Production images pulled from GHCR. Do not put tokens here. ----
# For production rollback, prefer an immutable tag such as sha-<short_sha>.
SANGUI_IMAGE_REGISTRY=ghcr.io/wusangui571/sanguiblog
SANGUI_IMAGE_TAG=main

# ---- Host web port. Default 8090 avoids common host Nginx 80/443 conflicts. ----
WEB_PORT=8090

# ---- Backend JVM memory guardrails inside the container. ----
JAVA_TOOL_OPTIONS=-Duser.timezone=Asia/Shanghai -Xms256m -Xmx512m

# ---- MySQL main database. Passwords are required in .env. ----
MYSQL_DATABASE=sanguiblog_db
MYSQL_USER=sanguiblog_user
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---- PostgreSQL / PgVector for optional AI RAG vector storage. ----
POSTGRES_DB=sanguiblog_ai
POSTGRES_USER=sanguiblog_pg_user
POSTGRES_PASSWORD=

# ---- Backend JWT secret. Required. Recommended length: 32+ characters. ----
# If the value contains $, wrap it in single quotes or escape each $ as $$.
JWT_SECRET=

# ---- Backend datasource. Keep this aligned with the MySQL values above. ----
# Use characterEncoding=utf8 here. Do not use characterEncoding=utf8mb4 in JDBC.
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/sanguiblog_db?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=sanguiblog_user
SPRING_DATASOURCE_PASSWORD=

# ---- Upload storage path inside the backend container. ----
STORAGE_BASE_PATH=/data/uploads

# ---- Site URL and allowed host names. ----
# Local/temporary default:
SITE_BASE_URL=http://localhost:8090
SITE_ALLOWED_HOSTS=localhost
#
# Production example for direct 8090 access:
# SITE_BASE_URL=http://new.sangui.top:8090
# SITE_ALLOWED_HOSTS=localhost,new.sangui.top
#
# Production example behind HTTPS reverse proxy:
# SITE_BASE_URL=https://new.sangui.top
# SITE_ALLOWED_HOSTS=localhost,new.sangui.top

# ---- Public asset base URL. ----
# Same-origin Docker deployment: leave empty. This is the recommended default.
# Do NOT set this to http://host:8090/uploads for same-origin deployments,
# otherwise uploaded asset URLs can become duplicated, such as /uploads/uploads/...
# Only set a complete URL when assets are served from a real CDN or separate host.
SITE_ASSET_BASE_URL=

# ---- CORS allowed origins. Must match the exact browser origin. ----
# The value must include scheme + host + port when a port is used.
# Local/temporary default:
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:8090
#
# Direct production example:
# SECURITY_CORS_ALLOWED_ORIGINS=http://new.sangui.top:8090
#
# HTTPS reverse-proxy example, with temporary 8090 kept during migration:
# SECURITY_CORS_ALLOWED_ORIGINS=https://new.sangui.top,http://new.sangui.top:8090

# ---- DashScope AI. Optional. Leave blank unless you have a real DashScope API key. ----
# Do NOT put your site URL here. A site URL such as http://new.sangui.top:8090 is invalid.
# If this is blank, keep AI_RAG_ENABLED=false.
AI_DASHSCOPE_API_KEY=

# ---- Optional AI RAG and PgVector connection. ----
# Safe production default: disabled. Enable only after AI_DASHSCOPE_API_KEY is real
# and PgVector connectivity has been verified.
AI_RAG_ENABLED=false
AI_RAG_SYNC_ON_STARTUP=false
AI_RAG_PGVECTOR_URL=jdbc:postgresql://pgvector:5432/sanguiblog_ai
AI_RAG_PGVECTOR_USERNAME=sanguiblog_pg_user
AI_RAG_PGVECTOR_PASSWORD=
AI_RAG_PGVECTOR_INITIALIZE_SCHEMA=false
